# Docker Hub source
DOCKERHUB_USER=giordanoberwig
IMAGE_TAG=v1.0.1
APP_PORT=8991
DOCKER_NETWORK_NAME=server-monitoring-network

# Required credentials (set your own values before running compose)
REVERB_APP_ID=replace-me
REVERB_APP_KEY=replace-me
REVERB_APP_SECRET=replace-me
