# ─── Frontend build args ──────────────────────────────────────────────────────
#
# VITE_METRICS_WS_URL is baked into the React bundle at build time.
# Nginx (frontend container) proxies /app/* to the backend container on port
# 8080, so clients always connect through port 80.
#
# Replace <REVERB_APP_KEY> with the value of REVERB_APP_KEY set in
# b-server-monitoring/.env — both values must match.
#
VITE_METRICS_WS_URL=ws://localhost/app/<REVERB_APP_KEY>?protocol=7&client=js&version=8.4.0&flash=false
VITE_METRICS_CHANNEL=metrics
