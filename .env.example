# ─── Frontend build args ──────────────────────────────────────────────────────
#
# VITE_METRICS_WS_URL is baked into the React bundle at build time.
# Use a relative path so the browser always connects back to the same host
# where the dashboard was opened (VM IP/domain), avoiding localhost mismatch.
#
# Replace <REVERB_APP_KEY> with the value of REVERB_APP_KEY set in
# b-server-monitoring/.env — both values must match.
#
VITE_METRICS_WS_URL=/app/<REVERB_APP_KEY>?protocol=7&client=js&version=8.4.0&flash=false
VITE_METRICS_CHANNEL=metrics
